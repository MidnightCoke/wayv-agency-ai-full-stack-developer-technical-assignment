# Copy this file to .env and fill in the values.

# Postgres connection string (Supabase, Neon, Railway, local, etc.)
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# OpenAI API key – highest priority. Leave empty to fall through to GROQ or mock.
OPENAI_API_KEY=

# GROQ API key – used when OPENAI_API_KEY is not set.
GROQ_API_KEY=